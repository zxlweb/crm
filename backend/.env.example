APP_ENV=development
GIN_MODE=debug
PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=crm

# 开发时可设为 true 启用 GORM AutoMigrate；生产请使用 make migrate-up
AUTO_MIGRATE=false

JWT_SECRET=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_TTL_MIN=60
REFRESH_TOKEN_TTL_DAYS=7

