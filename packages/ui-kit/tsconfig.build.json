{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/index.ts", "src/tokens/index.ts", "src/chart/**/*.ts", "src/theme/**/*.ts"],
  "exclude": ["src/**/*.vue", "src/nuxt/**", "src/runtime/**"]
}
