# 仅本机开发：localhost；局域网给他人演示请改为本机 IP，例如：
# NUXT_PUBLIC_API_BASE=http://192.168.11.175:8080
# 未设置时 dev 会自动探测 192.168.x / 10.x 网卡地址
NUXT_PUBLIC_API_BASE=http://localhost:8080# Phase 2.3 Leads：仅开发调试 mock 时设为 true
NUXT_PUBLIC_USE_LEADS_MOCK=false
NUXT_PUBLIC_USE_DEALS_MOCK=false
NUXT_PUBLIC_USE_DASHBOARD_MOCK=false
# Phase 4：settings / audit / admin insights（默认 false = 真实 API）
NUXT_PUBLIC_USE_SETTINGS_MOCK=false
NUXT_PUBLIC_USE_ADMIN_INSIGHTS_MOCK=false
